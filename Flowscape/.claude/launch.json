{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "flowscape-api",
      "runtimeExecutable": "../venv/Scripts/python.exe",
      "runtimeArgs": ["api_server.py"],
      "port": 8000
    },
    {
      "name": "web",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["--prefix", "../web", "run", "dev"],
      "port": 5173
    },
    {
      "name": "web-verify",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["--prefix", "../web", "run", "dev", "--", "--port", "5199", "--strictPort"],
      "port": 5199
    }
  ]
}
