.DS_Store

# Python virtual environment (machine-specific, never committed)
venv/

# Python bytecode caches (auto-generated, machine/version specific)
__pycache__/
*.pyc

# Affinity editor lock files (transient, created while a .af file is open)
*.af~lock~

# Generated visual-test renders (recreated by the test_*_visual.py scripts)
Flowscape/test_output/

# Web client: dependencies and build output (rebuilt with npm install / npm run build)
web/node_modules/
web/dist/

# Local archive of retired files (kept out of the repo)
archive/

# Per-machine Claude Code settings
.claude/settings.local.json

# Planning docs (kept local, not committed) — e.g. *_PLAN.md
*PLAN.md
